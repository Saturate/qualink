{
  "name": "qualink",
  "version": "0.2.0",
  "description": "Collect, normalize, and relay code quality metrics from CI",
  "license": "MIT",
  "type": "module",
  "bin": {
    "qualink": "bin/qualink.js"
  },
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ./bin/qualink.js",
    "dev": "node --loader ts-node/esm src/cli/index.ts",
    "lint": "biome check src/",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build",
    "changelog": "git-cliff -o CHANGELOG.md"
  },
  "dependencies": {
    "citty": "^0.2.1",
    "fast-xml-parser": "^5.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "git-cliff": "^2.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Saturate/qualink.git"
  },
  "homepage": "https://github.com/Saturate/qualink",
  "bugs": {
    "url": "https://github.com/Saturate/qualink/issues"
  },
  "keywords": [
    "ci",
    "code-quality",
    "elastic",
    "metrics"
  ],
  "publishConfig": {
    "access": "public"
  }
}
